# Django
DJANGO_SECRET_KEY=replace-me-with-a-long-random-string
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Supabase Postgres
# Use the "Session pooler" connection string from Supabase dashboard:
#   Project Settings -> Database -> Connection string -> URI (Session mode, port 5432)
# Format: postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres
DATABASE_URL=postgresql://postgres.xxxxxxxxxxxx:YOUR-DB-PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres

# Supabase Storage / API
# Project Settings -> API
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOi...   # safe to expose to frontend; keep server-side too
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...   # SERVER ONLY — never ship to the browser
SUPABASE_STORAGE_BUCKET=creatr-media

# CORS — Next.js dev origin
FRONTEND_ORIGIN=http://localhost:3000

# Google Sign-In
# Google Cloud Console -> APIs & Services -> Credentials -> OAuth 2.0 Client IDs
# Create a "Web application" client. Authorized JavaScript origins should include
# http://localhost:3000 for dev. The Client ID is safe to expose to the browser
# (the frontend reads the same value as NEXT_PUBLIC_GOOGLE_CLIENT_ID).
GOOGLE_CLIENT_ID=xxxxxxxxxxxx-xxxxxxxxxxxxxxxxxxxxxxxxxxxx.apps.googleusercontent.com


# Frontend URL — used to build the link inside verification emails.
# Dev: http://localhost:3000   Prod: https://creatr.com (or wherever Next.js is hosted)
FRONTEND_URL=http://localhost:3000

# Email — leave RESEND_API_KEY blank in dev; we'll send via SMTP/Mailtrap instead.
# In production, set RESEND_API_KEY and the helper switches to Resend's HTTP API.
DEFAULT_FROM_EMAIL=Creatr <onboarding@resend.dev>
EMAIL_VERIFICATION_TOKEN_HOURS=24

# --- Production: Resend (https://resend.com/api-keys) ---
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# --- Development: Mailtrap sandbox (https://mailtrap.io/inboxes) ---
# Mailtrap -> Email Testing -> Inboxes -> Integrations -> Django/SMTP
EMAIL_HOST=sandbox.smtp.mailtrap.io
EMAIL_PORT=2525
EMAIL_HOST_USER=your-mailtrap-username
EMAIL_HOST_PASSWORD=your-mailtrap-password
EMAIL_USE_TLS=True

# Optional override (useful for local debugging — prints emails to the console):
# DJANGO_EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
